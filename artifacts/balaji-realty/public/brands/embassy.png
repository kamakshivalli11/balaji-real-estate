html {scroll-behavior: smooth}:root {--white-100: #fff;--orange-100: #F58220;--orange-30: #FFBA8D;--black-100: #000;--gray-80: #666769;--gray-40: #E6E6E6;--gray-30: #F0F0F0;--gray-10: #FAFAFB;--header-height: 70px;--header-bg: #080808;--hero-height: 700px;--section-padding: 90px;--gray-100: #7F7F7F;} body {font-size: 16px; font-family: "Neulis Sans", Poppins; font-weight: 400; color: var(--bricks-color-joegtw)} h1, h2, h3, h4, h5, h6 {font-family: "Neulis Sans", Poppins; color: var(--bricks-color-joegtw)} h1 {font-size: 50px; font-family: "Neulis Sans"; font-weight: 400; line-height: 1} h2 {font-size: 25px} h3 {font-size: 20px} .brxe-section {padding-top: 70px; padding-right: var(--section-padding); padding-left: var(--section-padding)} .brxe-container {width: 1260px} .woocommerce main.site-main {width: 1260px} #brx-content.wordpress {width: 1260px}:where(:root) .bricks-color-primary {color: var(--bricks-color-joegtw)}:where(:root) .bricks-background-primary {background-color: var(--bricks-color-joegtw)} :root .bricks-button[class*="light"]:not(.bricks-lightbox) {color: var(--bricks-color-joegtw); font-size: 14px; font-weight: 400} .bricks-button {padding-top: 10px; padding-right: 20px; padding-bottom: 10px; padding-left: 20px; text-wrap: nowrap} :root .bricks-button[class*="dark"] {color: var(--bricks-color-ikuhve); font-size: 14px; font-family: "Neulis Sans"; font-weight: 500} :root .bricks-button[class*="dark"]:not(.outline) {background-color: var(--bricks-color-joegtw)} .bricks-button.md {padding-top: 13px; padding-right: 25px; padding-bottom: 13px; padding-left: 25px} :root .bricks-button[class*="secondary"] {font-family: "Neulis Sans"; font-size: 14px; font-weight: 500; color: var(--bricks-color-joegtw)} :root .bricks-button[class*="secondary"]:not(.outline) {background-color: var(--bricks-color-mcmvdd)} :root .bricks-button[class*="light"]:not(.outline):not(.bricks-lightbox) {background-color: rgba(0, 0, 0, 0)}body.header-black header#brx-header>section,body.