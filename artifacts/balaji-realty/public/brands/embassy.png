<script type='text/javascript'>(function() {
    // Only apply on small screens
    if (window.innerWidth > 477) return;

    function adjustButton() {
        const host = document.getElementById('voiceflow-chat');
        if (!host || !host.shadowRoot) return;

        const launcher = host.shadowRoot.querySelector('.vfrc-launcher__container');
        if (launcher) {
            launcher.style.bottom = '65px';
            return true; // adjustment done
        }
        return false;
    }

    // Try immediately in case widget is already loaded
    if (!adjustButton()) {
        // Observe for changes inside #voiceflow-chat
        const observer = new MutationObserver(() => {
            if (adjustButton()) {
                observer.disconnect(); // stop observing once done
            }
        });

        const host = document.getElementById('voiceflow-chat');
        if (host) {
            observer.observe(host, { childList: true, subtree: true });
        }
    }

    // Also adjust on resize just in case
    window.addEventListener('resize', adjustButton);
})();

</script><script id="bricks-scripts-js-extra">
