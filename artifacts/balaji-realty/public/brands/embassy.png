<script>
document.addEventListener('click', (e) => {
  const btn = e.target.closest('#brxe-vvswjp');
  if (!btn) return;

  e.preventDefault();
  e.stopPropagation();

  const toggle = document.querySelector('[data-script-id="bhnawi"]');
  if (toggle && toggle.getAttribute('aria-expanded') !== 'true') {
    toggle.click();
  }

  setTimeout(() => {
    const input = document.querySelector('#brxe-efbbsx .ids-live-search__input');
    if (input) {
      input.focus();
      input.click();
    }
   }, 300);
}, true);
</script>


