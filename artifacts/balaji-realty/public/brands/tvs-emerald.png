	    <script>
        jQuery(document).ready(function($) {
            $('a[href^="tel:"]').each(function() {
                const $link = $(this);
                const originalHref = $link.attr('href');
                const cleanedHref = 'tel:' + originalHref.replace('tel:', '').replace(/[^\d+]/g, '');
                $link.attr('href', cleanedHref);
            });
        });
    </script>
      <script>
    jQuery(document).ready(function($) {
      $('.search_box form').on('submit', function(e) {
        if ($.trim($('#search').val()) === '') {
          e.preventDefault();
        }
      });
    });
  </script>
