      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        'event': 'page_load_performance',
        'page_load_time': pageLoadTime,
        'server_response_time': serverResponseTime,
        'dom_content_loaded_time': domContentLoadedTime
      });
    }, 20)


  });
</script>

