</script><script>
  var headerHtOne = $("header.header_main.header_bg.residential_listing").outerHeight() || 0;
// console.log("header height - " + headerHtOne);

var bannerHtTwo = 0;
$(".about_us_bg_im,.Videoplaysection,section.client-hero-banner,section.commercial_completed_project,.communities_section_inside").each(function () {
  if ($(this).is(":visible")) {
    bannerHtTwo += $(this).outerHeight() || 0;
  }
});
bannerHtTwo = Math.max(0, bannerHtTwo - 300);

$(window).scroll(function () {
  var scrollHtTwo = $(window).scrollTop();
  // console.log("scroll top height - " + scrollHtTwo);

  var totalHtTwo = headerHtOne + bannerHtTwo;
  // console.log("total height - " + totalHtTwo);

  if (scrollHtTwo > totalHtTwo) {
    $('.wrapper_share_get').addClass('v-visible');
  } else {
    $('.wrapper_share_get').removeClass('v-visible');
  }
});

</script><script>
  function clickChatbubble(){
    var chatBubbleElement = document.getElementById("kenytChatBubble");
    chatBubbleElement && chatBubbleElement.click();
  }
</script><script>
  $(document).ready(function() {

    if ($(".navbar-toggler").hasClass('open')) {
        applyCSS();
    }

    $(".navbar-toggler").on('click', function() {
        if ($(this).hasClass('open')) {
            applyCSS();
        } else {
            removeCSS();
        }
    });

    function applyCSS() {
        $("html").css({
            'height': '101vh',
            'overflow': 'hidden',
        });
    }

    function removeCSS() {
        $("html").css({
            'height': 'auto',
            'overflow': 'auto',
        });
    }

  $(window).on("scroll", () => {

  if(($(document).height()-$(window).scrollTop()) < 800) {
   $(".wrapper_share_get").hide();
}
else {
  $(".wrapper_share_get").show();
}
  });


  setTimeout(function(){
    $(".look_for_spec_sec .flex_lin img").show();
  }, 5000);
    
});
</script></body></html>