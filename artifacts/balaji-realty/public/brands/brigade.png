        var phone = $('#mobile_code_reqcall').val();
        var currentPath = window.location.pathname;
        var wa_checkbox = $('#req_wabox');
        if (wa_checkbox.is(':checked')) {
          var whats_send = true;
        } else {
          var whats_send = false;
        }
        jQuery.ajax({
          type: "POST",
          url: '/residential/req-a-call/',
          data: {
          'contact': phone,
          'currentPath':currentPath,
          'country_code': countryCode,
          'contry_name_code':countryNameCode,
          'whats_App_info':whats_send,
          'g-recaptcha-response': token,
          'csrfmiddlewaretoken': 'jSv3bT3s6gULNx4pG33xVeNTaDIpPOEuzILtWchVxsQZexIgfws3U9Ksw6gqxkGt'
          },
          beforeSend:function(){  
            $('#pre_enq_req').css('opacity', '0.5');
              $('#pre_enq_req').prop('disabled', true);
              $(".loadingGif").show();
            
          }, 
          success: function (data) {
            setTimeout(function() {
            if (data){
              $(".loadingGif").hide();
