  $(function(){
        $(".call-trigger").click(function() {
          $(".modal.call-popUp-form").addClass("show-modal");
        })
       });
  
  
  var call_modal = document.querySelector(".modal.call-popUp-form");
  var call_modal_trigger = document.querySelector(".call-trigger");
  var call_closeButton = document.querySelector(".call-close-unit.call-close-button");
  
  function call_toggleModal() {
    call_modal.classList.toggle("show-modal");
  }
  
  function call_windowOnClick(event) {
      if (event.target === call_modal) {
        call_toggleModal();
      }
  }
  
  call_modal_trigger.addEventListener("click", call_toggleModal);
  call_closeButton.addEventListener("click", call_toggleModal);
  window.addEventListener("click", call_windowOnClick);
