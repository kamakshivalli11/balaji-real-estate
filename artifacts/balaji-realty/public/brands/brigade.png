      var prevScrollpos = window.pageYOffset;
      window.onscroll = function () {
        if (document.body.scrollTop > 100 || document.documentElement.scrollTop > 100) {
        var currentScrollPos = window.pageYOffset;
        if (prevScrollpos > currentScrollPos) {
          document.getElementById("navbar").style.top = "0";
          document.getElementById("navbar").classList.add('black_class_header');
        } else {
          document.getElementById("navbar").style.top = "-145px";
          $("#navbar").css("background-color", "white");
        }
        prevScrollpos = currentScrollPos;
      }
    }
    </script><script>
       if($(window).width() > 1024) {
      var lastScrollTop = 0;
      $(window).scroll(function(){
  
        var st = $(this).scrollTop();
     if (st > lastScrollTop){
         $('#navbar').addClass('white_class_header');
         $('#navbar').removeClass('black_class_header');
     } else {
        $('#navbar').addClass('white_class_header');
        $('#navbar').addClass('black_class_header');
  
     }
     lastScrollTop = st;
      if ($(this).scrollTop() == 0) {
         $('#navbar').removeClass('white_class_header');
         $('#navbar').removeClass('black_class_header');
      } else {
         $('#navbar').removeClass('reverse_scroll_cls');
      }
  });
}

if($(window).width() <= 1024) {
var position = jQuery(window).scrollTop();
jQuery(window).scroll(function() {
	var scroll = jQuery(window).scrollTop();
	if (scroll > position) {
		if (scroll > 10) {
			jQuery('body').addClass('translate-header')
		}
	} else {
		jQuery('body').removeClass('translate-header');
		if (scroll < 10) {
      $('#navbar').addClass('white_class_header');
			$('#navbar').removeClass('black_class_header');
		} else {
			$('#navbar').addClass('black_class_header');
      $('#navbar').removeClass('white_class_header');
		}
	}
	position = scroll
}).scroll();
}
  
