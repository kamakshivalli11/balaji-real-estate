</script><script>
  function showFlashMessageREQcall(message, formId, msgId, modalId) {
        var $msg = $('#' + msgId);
        var $form = $('#' + formId);
        var $modal = $('#' + modalId);

        $msg.text(message).css({
            "color": "red",
            "display": "block",
            "font-weight": "bold",
            "margin-bottom": "10px"
        });

        setTimeout(function() {
            $msg.fadeOut(500, function() {
                $msg.text("");
                // Check if modal exists before trying to fade out
                if ($modal.length) $modal.fadeOut(500);
                
                // Reset the specific form passed to the function
                if ($form.length) $form[0].reset();
            });
        }, 5000);
  }
  $().ready(function() {
