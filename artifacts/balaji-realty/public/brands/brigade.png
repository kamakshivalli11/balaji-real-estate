              window.location.href = '/thank-you/?params=' + encodeURIComponent(currentUrl);
            }
          }, 4000);
      
          },
          error: function (xhr, textStatus, errorThrown) {
              // This runs if the status is NOT 2xx (e.g., 400, 500)
              $(".loadingGif").hide();
              $('#pre_enq_req').css('opacity', '1');
              $('#pre_enq_req').prop('disabled', false);
              var msg = "Something went wrong. Please try again." ;
              showFlashMessageREQcall(msg, 'call-form-unit', 'msgnew', "call-popUp-form-modal-popup");
              
          },
        });
